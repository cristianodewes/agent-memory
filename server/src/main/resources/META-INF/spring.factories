# Bridge agent-memory.server.base-path -> server.servlet.context-path so /api/v1, /mcp and /web
# relocate together behind a proxy (issue #35). EnvironmentPostProcessors must be registered here
# (not via AutoConfiguration.imports) because they run before the application context exists.
org.springframework.boot.env.EnvironmentPostProcessor=\
  com.agentmemory.web.BasePathEnvironmentPostProcessor
