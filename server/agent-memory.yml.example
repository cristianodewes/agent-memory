# agent-memory server configuration (example).
#
# Copy this file to `agent-memory.yml` next to where you start the server, or point
# AGENT_MEMORY_CONFIG at it. Every value below is optional and shown at its built-in default;
# delete the keys you don't need. Environment variables override this file (e.g. set
# AGENT_MEMORY_SERVER_PORT to override agent-memory.server.port), which overrides these defaults.
#
# Precedence (lowest first):  built-in defaults  ->  this file  ->  environment variables.

agent-memory:
  server:
    address: 127.0.0.1   # loopback by default (DD-007); set 0.0.0.0 to expose (then enable auth)
    port: 8080
    base-path: /

  data:
    # Canonical data dir. Resolved to an absolute path and created at startup; a leading ~ is
    # expanded to your home directory. Holds wiki/ raw/ db/ logs/.
    dir: ~/.agent-memory

  db:
    url: jdbc:postgresql://127.0.0.1:5432/agent_memory
    username: agent_memory
    password: ""

  # LLM is required at runtime (DD-005, invariant #13): the server probes it at startup and
  # fails fast if it is unreachable. Pick ONE provider below.
  llm:
    auth:
      provider: ""       # anthropic | openai | openai-compat | openai-oauth | gemini
      api-key: ""        # secret key; LEAVE EMPTY for keyless local engines (see openai-compat)
      base-url: ""       # override endpoint; REQUIRED for openai-compat, optional otherwise
      model: ""          # model id; required for openai-compat / local engines (no universal default)
      # oauth:           # only for provider=openai-oauth (the credential lives in a token file)
      #   token-file: "" # optional; default <data-dir>/auth.json (written by `auth login openai-oauth`)

    # --- worked examples (copy one into `auth:` above) -------------------------------------------
    #
    # OpenAI (native): base-url defaults to https://api.openai.com/v1; model defaults to gpt-5.5.
    #   auth:
    #     provider: openai
    #     api-key: ${OPENAI_API_KEY}
    #     model: gpt-5.5
    #
    # OpenRouter (OpenAI-compatible gateway, with key): one key, hundreds of models.
    #   auth:
    #     provider: openai-compat
    #     base-url: https://openrouter.ai/api/v1
    #     api-key: ${OPENROUTER_API_KEY}
    #     model: deepseek/deepseek-chat
    #
    # Ollama (local, KEYLESS): leave api-key empty — no Authorization header is sent.
    #   auth:
    #     provider: openai-compat
    #     base-url: http://localhost:11434/v1
    #     model: llama3.1
    #
    # OpenAI via OAuth (ChatGPT subscription login, no per-token API key): requests go to the Codex
    # Responses backend (chatgpt.com/backend-api/codex/responses), NOT api.openai.com. Sign in ONCE
    # with the client — it writes the token to <data-dir>/auth.json — then the server reads + refreshes
    # it. The credential is NOT pasted here; config only selects the provider:
    #   $ agent-memory auth login openai-oauth   # --data-dir = the SERVER's data dir
    #   auth:
    #     provider: openai-oauth
    #     model: gpt-5.5                # optional (default gpt-5.5)
    #     # oauth:
    #     #   token-file: ""            # optional; default <data-dir>/auth.json
    #     # base-url: ""                # optional; overrides the Codex Responses endpoint
    # The Codex client id / login + refresh endpoints are fixed in code (unofficial, may change).
    #
    # Any other OpenAI-compatible engine (vLLM, LM Studio, llama.cpp server, Groq, Together,
    # DeepSeek, Mistral, Gemini's OpenAI-compatible endpoint) works the same way: set
    # provider=openai-compat, point base-url at the engine, set model, add api-key only if required.

  # LLM-assisted recall (issues #21/#130). Drives BOTH the /recall/inject hook (fires on every prompt,
  # bounded by the client's 10s deadline) AND MCP memory_query. Values shown are the built-in defaults;
  # delete keys you don't need.
  recall:
    # Recency prior on the BASE hybrid fusion (issue #140): multiplies each fused hit's score by a
    # per-layer exponential decay of its age (since pages.updated_at), so a fresher page outranks an
    # equally-relevant stale one. Applied below the `llm` rerank — it shapes the candidate pool and the
    # non-LLM fast-path order; the cross-encoder then re-scores the head by pure relevance. Semantic and
    # procedural pages do not age-decay. NB: a full reindex re-stamps updated_at, so after one a page's
    # recency reflects the rebuild time, not its real edit.
    recency:
      enabled: true                  # master switch; false = untouched base RRF order
      working-half-life-days: 1.0    # half-life (days) for WORKING pages (session scratch); 0 = off
      episodic-half-life-days: 14.0  # half-life (days) for EPISODIC pages (events fade ~2 weeks); 0 = off
    llm:
      enabled: true            # master switch for the LLM rerank decorator; false = raw hybrid (RRF)
      max-candidates: 8        # K: how many fused candidates the LLM re-scores (renders at most 5)
      budget-ms: 6000          # wall-clock budget for the LLM steps; on exhaustion recall returns the
                               # already-computed hybrid result (never empty) and bounds the call's HTTP
                               # timeout — keep comfortably under the client's 10s deadline
      minimal-reasoning: true  # ask the recall calls for minimal reasoning effort (+ low verbosity) to
                               # cut a reasoning model's hidden-reasoning latency. Set false if a backend
                               # rejects the `reasoning`/`verbosity` params (rerank then degrades to RRF).
      auth:                    # OPTIONAL recall provider/model (Fase 5, issue #146). Routes ONLY the LLM
                               # recall steps (brief synthesis, the rerank fallback, expansion) to a
                               # separate, cheaper/faster model; chat + consolidation keep the primary
                               # llm.auth above. Same shape as llm.auth. EMPTY (the default) => recall
                               # reuses the primary chat provider — zero change. Best-effort: a bad recall
                               # model only degrades recall to the fast RRF/bullets path, never fails
                               # startup, and it is NOT probed at boot.
        provider: ""           # provider set => an INDEPENDENT provider on its own key (a mini/flash/
                               #   haiku model); ONLY model set (provider empty) => the primary's
                               #   provider/key/oauth with just the model swapped; both empty => primary
        api-key: ""
        base-url: ""
        model: ""
      # --- worked examples (copy one into `auth:` above) -----------------------------------------
      #   # an independent cheap model on its own key:
      #   auth:
      #     provider: openai
      #     api-key: ${OPENAI_API_KEY}
      #     model: gpt-5.5-mini
      #   # or the SAME chat provider/key, just a smaller model for the recall steps:
      #   auth:
      #     model: gpt-5.5-mini   # provider empty => reuse llm.auth's provider/key/oauth, swap the model
      cache:                   # short-TTL result cache (Fase 4): memoizes the recall RESULT per
                               # (workspace, project, normalized prompt, limit) so repeated/reformulated
                               # prompts in a session skip the embed + DB + cross-encoder work. TTL is the
                               # only invalidation (an entry just expires after a reindex); the scope is in
                               # the key, so a hit is never shared across projects.
        enabled: true          # false makes the cache a transparent pass-through (every search delegates)
        ttl: 45s               # how long a cached result stays fresh; keep short (tens of seconds) so it
                               # only collapses in-session repeats and post-reindex staleness stays bounded
        max-entries: 256       # LRU bound on distinct (scope, prompt, limit) entries; eldest evicted past it
      cross-encoder:           # calibrated cross-encoder rerank (Fase 2). Reuses the SAME Voyage API key
                               # as embeddings (below) — active only when embeddings.auth is Voyage + key.
        enabled: true          # false forces the generative LLM reranker; absent Voyage => LLM reranker
        model: rerank-2-lite   # Voyage rerank model (fast, non-generative, calibrated 0..1 score)
        max-documents: 50      # cap on candidates scored per rerank call; the head is min(this, pool),
                               # and the pool is max(query.limit, max-candidates) — right-sizes K cheaply
      mmr:                     # MMR diversity (Fase 4): after the rerank and before the trim, re-order the
                               # candidates by relevance − redundancy over their embeddings so the injected
                               # block is not several bullets of one topic. Pure CPU + one bounded by-id
                               # embeddings query (NOT bounded by budget-ms); only has an effect when
                               # embeddings exist, and degrades to the rerank order otherwise.
        enabled: true          # false keeps the pure rerank order (it is a no-op when embeddings are absent)
        lambda: 0.7            # relevance/diversity trade-off in [0,1]; higher favours relevance (conservative)
      expansion:
        enabled: false         # query expansion is off by default: appending terms to the conjunctive
                               # FTS query only narrows recall and dilutes the embedding centroid (IR bug)
      injection:
        min-score: 0.4         # relative relevance gate for the injected block (fraction of the top hit's
                               # score); suppresses weak bullets on low-signal prompts. 0.0 = admit all.
        min-score-absolute: 0.35 # absolute floor applied ONLY when a calibrated cross-encoder ran: if even
                               # the top hit is below it, inject nothing (calibrated "nothing relevant").
                               # Never applied to uncalibrated RRF/LLM scores.
        brief:                 # synthesized brief (Fase 3): when the calibrated gate approves, replace the
                               # raw snippet bullets with one short cited paragraph via a single minimal-
                               # effort generative call. Only fires on real matches (low-signal prompts
                               # never reach it); any failure/timeout/not-relevant falls back to the bullets.
          enabled: false       # OFF by default: reintroduces a generative call (latency + Codex cost) and a
                               # prompt-injection surface — enable per deployment after validating in prod
          timeout-ms: 4000     # per-call HTTP timeout bounding the single brief call; on timeout the block
                               # falls back to the bullets. Keep under the client's 10s deadline minus the
                               # recall search already spent (the brief runs only after a fast calibrated search)

  embeddings:
    auth:
      provider: ""
      api-key: ""
      base-url: ""
      model: ""

  # Server auth is a stub here; enforcement lands in issue #38.
  auth:
    enabled: false       # false = loopback-only, no token required (DD-007)
    token: ""
