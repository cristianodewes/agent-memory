# agent-memory server configuration (example).
#
# Copy this file to `agent-memory.yml` next to where you start the server, or point
# AGENT_MEMORY_CONFIG at it. Every value below is optional and shown at its built-in default;
# delete the keys you don't need. Environment variables override this file (e.g. set
# AGENT_MEMORY_SERVER_PORT to override agent-memory.server.port), which overrides these defaults.
#
# Precedence (lowest first):  built-in defaults  ->  this file  ->  environment variables.

agent-memory:
  server:
    address: 127.0.0.1   # loopback by default (DD-007); set 0.0.0.0 to expose (then enable auth)
    port: 8080
    base-path: /

  data:
    # Canonical data dir. Resolved to an absolute path and created at startup; a leading ~ is
    # expanded to your home directory. Holds wiki/ raw/ db/ logs/.
    dir: ~/.agent-memory

  db:
    url: jdbc:postgresql://127.0.0.1:5432/agent_memory
    username: agent_memory
    password: ""

  # LLM is required at runtime (DD-005, invariant #13): the server probes it at startup and
  # fails fast if it is unreachable. Pick ONE provider below.
  llm:
    auth:
      provider: ""       # anthropic | openai | openai-compat | gemini
      api-key: ""        # secret key; LEAVE EMPTY for keyless local engines (see openai-compat)
      base-url: ""       # override endpoint; REQUIRED for openai-compat, optional otherwise
      model: ""          # model id; required for openai-compat / local engines (no universal default)

    # --- worked examples (copy one into `auth:` above) -------------------------------------------
    #
    # OpenAI (native): base-url defaults to https://api.openai.com/v1; model defaults to gpt-5.5.
    #   auth:
    #     provider: openai
    #     api-key: ${OPENAI_API_KEY}
    #     model: gpt-5.5
    #
    # OpenRouter (OpenAI-compatible gateway, with key): one key, hundreds of models.
    #   auth:
    #     provider: openai-compat
    #     base-url: https://openrouter.ai/api/v1
    #     api-key: ${OPENROUTER_API_KEY}
    #     model: deepseek/deepseek-chat
    #
    # Ollama (local, KEYLESS): leave api-key empty — no Authorization header is sent.
    #   auth:
    #     provider: openai-compat
    #     base-url: http://localhost:11434/v1
    #     model: llama3.1
    #
    # Any other OpenAI-compatible engine (vLLM, LM Studio, llama.cpp server, Groq, Together,
    # DeepSeek, Mistral, Gemini's OpenAI-compatible endpoint) works the same way: set
    # provider=openai-compat, point base-url at the engine, set model, add api-key only if required.

  embeddings:
    auth:
      provider: ""
      api-key: ""
      base-url: ""
      model: ""

  # Server auth is a stub here; enforcement lands in issue #38.
  auth:
    enabled: false       # false = loopback-only, no token required (DD-007)
    token: ""
